      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst updatedItems = items.map((item) => {\n  const message = item.json.Template || '';\n  \n  const formattedMessage = `<div style=\"font-size:14px; line-height:1.6;\">${message.replace(/\\n/g, \"<br>\").replaceAll('    ', '&nbsp;&nbsp;&nbsp;&nbsp;')}<br><h5 style=\"margin: 0; font-size: 12px; color: #666666;\">\n                            To unsubscribe from such emails, please click \n                              <a href=\"https://signup.knolens.com/unsubscribe?email={Email}&name={FirstName}\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"color: #0c6372; text-decoration: underline;\">Unsubscribe</a>\n                          </h5></div>`;\n  \n  item.json.Template = formattedMessage;\n  return item;\n});\n\nreturn updatedItems;"
      },
