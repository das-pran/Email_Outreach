      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nreturn items.map(item => {\n  const row = item.json;\n\n  // Parse dd/mm/yyyy safely into a real Date object\n  const [day, month, year] = row.date.split('/');\n  const parsedDate = new Date(`${year}-${month}-${day}`);\n\n  return {\n    json: {\n      name: row[\"First Name\"],                                 // string (no change)\n      email: row[\"Email\"], \n      title: row[\"Title\"],// string (no change)\n      company: row[\"Company\"],\n      designation:row.designation,\n      drug_name: row.drug_name,// string (no change)\n      status: row.status,  \n      folow_up_number :row.folow_up_number,// string (you can customize if \n      date: parsedDate,                       // convert string to Date object\n      indication: row.indication,\n      phase: row.phase,\n      signature: `<div style=\"margin-top: 20px; line-height: 1.6; color: #333333;\">\n                      <div style=\"margin-bottom: 5px;\"><strong>Kind Regards,</strong></div>\n                      <div style=\"font-weight: bold;\">Eesha Joshi</div>\n                      <div>Data Analyst</div>\n                      <div><a href=\"mailto:eesha.joshi@pienomial.com\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"color: #0c6372; text-decoration: underline;\">eesha.joshi@pienomial.com</a></div>\n                      <div>\n                        <a href=\"https://www.pienomial.com/\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"color: #0c6372; text-decoration: underline;\">Pienomial</a> | \n                        <a href=\"https://www.linkedin.com/in/eesha-joshi-552813204/\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"color: #0c6372; text-decoration: underline;\">LinkedIn</a>\n                      </div>\n                      <div style=\"margin-top: 10px;\">\n                        <img width=\"96\" height=\"36\" src=\"https://ci3.googleusercontent.com/mail-sig/AIorK4xNTHpGKEvfyDGjz1iVfPYmiFn34NUBMOk4uvO51Hh4aDpC6DtwG0VJpBd6uqDD31EZKl042WQ38sEO\" alt=\"Signature\" style=\"border: 0; height: auto; display: block;\">\n                      </div>\n                    </div>`,\n    }\n  };\n});\n\n"
      },
